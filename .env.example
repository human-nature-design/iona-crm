# ===========================================
# Local Development (supabase start)
# ===========================================
# Run `npx supabase start` to get these values.
# The anon key and service_role key are printed in the terminal output.

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
ADMIN_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<anon key from supabase start>
SUPABASE_SECRET_KEY=<service_role key from supabase start>

# ===========================================
# Hosted Supabase (alternative to local)
# ===========================================
# DATABASE_URL=postgresql://app_user.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=verify-full
# ADMIN_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=verify-full
# NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# ===========================================
# Stripe
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ===========================================
# App Config
# ===========================================
BASE_URL=http://localhost:3000
AUTH_SECRET=replace-me  # Generate with: openssl rand -hex 32

# Google OAuth (optional)
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=


# ===========================================
# AI
# ===========================================
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===========================================
# Email (optional)
# ===========================================
# RESEND_API_KEY=re_...

# ===========================================
# Testing (optional)
# ===========================================
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
